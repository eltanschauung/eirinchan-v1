<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title suffix=" · Phoenix Framework">
      <%= assigns[:page_title] || "Eirinchan" %>
    </.live_title>
    <link
      phx-track-static
      rel="stylesheet"
      href={versioned_asset(~p"/assets/app.css", assigns[:asset_version])}
    />
    <link
      :if={assigns[:theme_stylesheet]}
      phx-track-static
      rel="stylesheet"
      href={versioned_asset(assigns[:theme_stylesheet], assigns[:asset_version])}
    />
    <script
      defer
      phx-track-static
      type="text/javascript"
      src={versioned_asset(~p"/assets/app.js", assigns[:asset_version])}
    >
    </script>
    <script
      :for={script_url <- assigns[:custom_javascript_urls] || []}
      defer
      type="text/javascript"
      src={versioned_asset(script_url, assigns[:asset_version])}
    >
    </script>
  </head>
  <body class="bg-white antialiased">
    <section
      :if={assigns[:theme_options] && assigns[:theme_options] != []}
      class="flex justify-end px-4 pt-3 sm:px-6 lg:px-8"
    >
      <form action={~p"/theme"} method="post" class="flex items-center gap-2 text-sm">
        <input type="hidden" name="_csrf_token" value={get_csrf_token()} />
        <input type="hidden" name="return_to" value={assigns[:conn].request_path} />
        <label for="theme-select">Theme</label>
        <select id="theme-select" name="theme">
          <%= for option <- @theme_options do %>
            <option value={option.name} selected={@theme_name == option.name}>
              <%= option.label %>
            </option>
          <% end %>
        </select>
        <button type="submit">Apply</button>
      </form>
    </section>
    <%= @inner_content %>
  </body>
</html>

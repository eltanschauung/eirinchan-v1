<div class="thread watcher-page-shell">
  <div class="post reply watcher-page-panel">
    <div class="banner">
      <.board_banner />
    </div>
    <header>
      <h1>Thread Watcher</h1>
      <div class="subtitle">Threads watched by this browser token.</div>
      <.admin_shortcuts moderator={@current_moderator} />
    </header>
    <hr />
    <.watcher_list watch_summaries={@watch_summaries} />
    <hr />
  </div>
</div>
